# Credenciais do projeto Supabase (Project Settings → API)
# Copie este arquivo para `.env` e preencha com os valores reais.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# ID da loja padrão (single-store, sem subdomínio)
# Buscar com: SELECT id FROM stores WHERE slug = 'brothers-story';
VITE_DEFAULT_STORE_ID=00000000-0000-0000-0000-000000000001
